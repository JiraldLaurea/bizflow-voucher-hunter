NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (libSQL / Turso).
# Local dev & tests use a local SQLite file via DATABASE_PATH (below).
# For production (Vercel), create a Turso database and set:
#   DATABASE_URL=libsql://your-db-name-org.turso.io
#   DATABASE_AUTH_TOKEN=your-turso-auth-token
# When DATABASE_URL is set it takes precedence over DATABASE_PATH.
DATABASE_PATH=./data/bizflow.db
# DATABASE_URL=
# DATABASE_AUTH_TOKEN=

# SMS provider: mock|smpp|movider|twilio|infobip|clicksend
# mock logs "[SMS MOCK] To: ..." to the console and always succeeds; use it
# for local dev. Leave unset to default to mock.
SMS_PROVIDER=mock
# SMS_API_KEY=
# SMS_API_SECRET=
# SMS_SENDER_ID=BizFlow

# SMPP (direct SMSC / local Philippine SMS aggregator). Used when SMS_PROVIDER=smpp.
# SMS_PROVIDER=smpp
# SMPP_HOST=smsc.example.com
# SMPP_PORT=2775
# SMPP_SYSTEM_ID=your_smpp_system_id
# SMPP_PASSWORD=your_smpp_password
# SMPP_BIND_TYPE=transceiver          # transceiver | transmitter
# Registered sender IDs. A per-carrier match is used when set; otherwise the default.
# SMPP_SOURCE_ADDR=BizFlow            # default sender (falls back to SMS_SENDER_ID)
# SMPP_SOURCE_ADDR_SMART=your_smart_sender_id
# SMPP_SOURCE_ADDR_GLOBE=your_globe_sender_id
# Address TON/NPI. Defaults suit alphanumeric sender + international MSISDN.
# SMPP_SOURCE_ADDR_TON=5
# SMPP_SOURCE_ADDR_NPI=0
# SMPP_DEST_ADDR_TON=1
# SMPP_DEST_ADDR_NPI=1
# SMPP_REGISTERED_DELIVERY=1          # 1 = request delivery receipts (DLR)
# Optional tuning (milliseconds) and diagnostics.
# SMPP_BIND_TIMEOUT_MS=30000
# SMPP_CONNECT_TIMEOUT_MS=30000
# SMPP_SUBMIT_TIMEOUT_MS=30000
# SMPP_ENQUIRE_LINK_MS=10000
# SMPP_DEBUG=false

# Movider (Philippines) -- https://developer.movider.co
# SMS_PROVIDER=movider
# SMS_API_KEY=your_movider_api_key
# SMS_API_SECRET=your_movider_api_secret
# SMS_SENDER_ID=BizFlow

# Twilio
# SMS_PROVIDER=twilio
# SMS_API_KEY=your_twilio_account_sid
# SMS_API_SECRET=your_twilio_auth_token
# SMS_SENDER_ID=+1234567890

# Infobip
# SMS_PROVIDER=infobip
# SMS_API_KEY=your_infobip_api_key
# INFOBIP_BASE_URL=https://XXXXX.api.infobip.com
# SMS_SENDER_ID=BizFlow

# ClickSend
# SMS_PROVIDER=clicksend
# SMS_API_KEY=your_clicksend_username
# SMS_API_SECRET=your_clicksend_api_key
# SMS_SENDER_ID=BizFlow

# Dashboard login. Replace every example value before deployment.
ADMIN_NAME=BizFlow Admin
ADMIN_EMAIL=admin@bizflow.local
ADMIN_PASSWORD=change-this-admin-password
# Generate a long random value (at least 32 characters). Changing it logs out
# every active admin session.
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters

# Optional server-only bearer token for trusted scripts/integrations.
# Never expose this value through a NEXT_PUBLIC_ variable.
ADMIN_ACCESS_TOKEN=local-admin-integration-token

# Optional salt for hashing OTP codes at rest (defaults to ADMIN_ACCESS_TOKEN).
# OTP_SALT=replace-with-random-value
# Optional salt for hashing IPs in the rate-limit table (defaults to ADMIN_ACCESS_TOKEN).
# RATE_LIMIT_SALT=replace-with-random-value
